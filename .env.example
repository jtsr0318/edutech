SECRET_KEY=change-me-in-production
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=edutech
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app

